# Copy this file to .env and fill in your values.

# Required: your Discord bot token (https://discord.com/developers/applications)
DISCORD_TOKEN=

# Optional: a Discord channel webhook URL. When set, every grade done on the
# website is mirrored into that Discord channel, so the site and the bot share one
# feed. Leave blank to disable (the site then posts nowhere). Create one under
# Channel Settings → Integrations → Webhooks.
DISCORD_WEBHOOK_URL=
# Optional: the channel id the webhook posts to (for reference/tooling).
DISCORD_CHANNEL_ID=

# Optional: a pokemontcg.io API key. Without one you still get a lower free rate
# limit, which is fine for personal use. Get one at https://dev.pokemontcg.io/
POKEMONTCG_API_KEY=

# Optional tuning -------------------------------------------------------------
# Max perceptual-hash hamming distance to still consider a card "matched".
# Lower = stricter. 22 is a reasonable default for phone photos.
MATCH_MAX_DISTANCE=22
